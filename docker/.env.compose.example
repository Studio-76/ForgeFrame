FORGEFRAME_PG_USER=forgeframe
FORGEFRAME_PG_PASSWORD=replace-with-a-generated-postgres-password
FORGEFRAME_PG_DB=forgeframe
FORGEFRAME_PG_PORT=5432
FORGEFRAME_APP_PORT=8000
FORGEFRAME_POSTGRES_URL=postgresql+psycopg://forgeframe:replace-with-a-generated-postgres-password@postgres:5432/forgeframe
FORGEFRAME_HARNESS_STORAGE_BACKEND=postgresql
FORGEFRAME_CONTROL_PLANE_STORAGE_BACKEND=postgresql
FORGEFRAME_OBSERVABILITY_STORAGE_BACKEND=postgresql
FORGEFRAME_GOVERNANCE_STORAGE_BACKEND=postgresql
FORGEFRAME_HARNESS_POSTGRES_URL=postgresql+psycopg://forgeframe:replace-with-a-generated-postgres-password@postgres:5432/forgeframe
FORGEFRAME_CONTROL_PLANE_POSTGRES_URL=postgresql+psycopg://forgeframe:replace-with-a-generated-postgres-password@postgres:5432/forgeframe
FORGEFRAME_OBSERVABILITY_POSTGRES_URL=postgresql+psycopg://forgeframe:replace-with-a-generated-postgres-password@postgres:5432/forgeframe
FORGEFRAME_GOVERNANCE_POSTGRES_URL=postgresql+psycopg://forgeframe:replace-with-a-generated-postgres-password@postgres:5432/forgeframe
FORGEFRAME_BOOTSTRAP_ADMIN_USERNAME=admin
FORGEFRAME_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-generated-bootstrap-password

# Optional local-provider validation path. Keep unset for the default 2-service stack.
# The URL must be reachable from inside the ForgeFrame container; do not use localhost here.
# FORGEFRAME_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# FORGEFRAME_OLLAMA_DEFAULT_MODEL=llama3.2
# FORGEFRAME_OLLAMA_VALIDATION_MODEL=llama3.2

# Optional OAuth/account probes (empty by default for local bootstrap)
FORGEFRAME_OPENAI_CODEX_OAUTH_ACCESS_TOKEN=
FORGEFRAME_GEMINI_OAUTH_ACCESS_TOKEN=
FORGEFRAME_ANTIGRAVITY_OAUTH_ACCESS_TOKEN=
FORGEFRAME_GITHUB_COPILOT_OAUTH_ACCESS_TOKEN=
FORGEFRAME_CLAUDE_CODE_OAUTH_ACCESS_TOKEN=
FORGEFRAME_ANTHROPIC_API_KEY=
