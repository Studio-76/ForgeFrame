FORGEGATE_PG_USER=forgegate
FORGEGATE_PG_PASSWORD=forgegate
FORGEGATE_PG_DB=forgegate
FORGEGATE_PG_PORT=5432
FORGEGATE_APP_PORT=8000
FORGEGATE_POSTGRES_URL=postgresql+psycopg://forgegate:forgegate@postgres:5432/forgegate
FORGEGATE_HARNESS_STORAGE_BACKEND=postgresql
FORGEGATE_CONTROL_PLANE_STORAGE_BACKEND=postgresql
FORGEGATE_OBSERVABILITY_STORAGE_BACKEND=postgresql
FORGEGATE_GOVERNANCE_STORAGE_BACKEND=postgresql
FORGEGATE_HARNESS_POSTGRES_URL=postgresql+psycopg://forgegate:forgegate@postgres:5432/forgegate
FORGEGATE_CONTROL_PLANE_POSTGRES_URL=postgresql+psycopg://forgegate:forgegate@postgres:5432/forgegate
FORGEGATE_OBSERVABILITY_POSTGRES_URL=postgresql+psycopg://forgegate:forgegate@postgres:5432/forgegate
FORGEGATE_GOVERNANCE_POSTGRES_URL=postgresql+psycopg://forgegate:forgegate@postgres:5432/forgegate
FORGEGATE_BOOTSTRAP_ADMIN_USERNAME=admin
FORGEGATE_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# Optional local-provider validation path. Keep unset for the default 2-service stack.
# The URL must be reachable from inside the ForgeGate container; do not use localhost here.
# FORGEGATE_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# FORGEGATE_OLLAMA_DEFAULT_MODEL=llama3.2
# FORGEGATE_OLLAMA_VALIDATION_MODEL=llama3.2

# Optional OAuth/account probes (empty by default for local bootstrap)
FORGEGATE_OPENAI_CODEX_OAUTH_ACCESS_TOKEN=
FORGEGATE_GEMINI_OAUTH_ACCESS_TOKEN=
FORGEGATE_ANTIGRAVITY_OAUTH_ACCESS_TOKEN=
FORGEGATE_GITHUB_COPILOT_OAUTH_ACCESS_TOKEN=
FORGEGATE_CLAUDE_CODE_OAUTH_ACCESS_TOKEN=
FORGEGATE_ANTHROPIC_API_KEY=
